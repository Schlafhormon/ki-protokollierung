# HuggingFace token for pyannote diarization (required)
# Create token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
# HUGGINGFACE_TOKEN is accepted as an alias when HF_TOKEN is not set.
# HUGGINGFACE_TOKEN=your_huggingface_token_here

# WhisperX configuration
WHISPER_MODEL=large-v2
WHISPER_DEVICE=auto
WHISPER_BATCH_SIZE=16
WHISPER_CPU_THREADS=4
# Optional CPU tuning for long CPU-only transcription jobs.
# TORCH_NUM_THREADS=16
# TORCH_NUM_INTEROP_THREADS=1
# OMP_NUM_THREADS=16
# MKL_NUM_THREADS=16
WHISPER_LANGUAGE=de

# Conservative cross-recording speaker suggestions via PyAnnote embeddings.
# Matches are reviewable suggestions only; they are never auto-confirmed.
SPEAKER_EMBEDDING_ENABLED=true
SPEAKER_EMBEDDING_MODEL=pyannote/embedding
SPEAKER_EMBEDDING_FALLBACK_MODELS=pyannote/wespeaker-voxceleb-resnet34-LM
SPEAKER_MATCH_AUTO_THRESHOLD=0.82
SPEAKER_MATCH_SUGGEST_THRESHOLD=0.72
SPEAKER_MATCH_TOP_K=3
SPEAKER_EMBEDDING_MIN_SECONDS=8.0
SPEAKER_EMBEDDING_MIN_SEGMENT_SECONDS=1.5
SPEAKER_EMBEDDING_MAX_SEGMENT_SECONDS=12.0
SPEAKER_EMBEDDING_MAX_SEGMENTS=8
SPEAKER_PROFILE_MAX_EMBEDDINGS_PER_MODEL=16
TORCH_FORCE_NO_WEIGHTS_ONLY_LOAD=1

# Ollama configuration for local backend development
# Docker Compose sets APP_RUNTIME=docker and uses http://ollama:11434/v1 by default.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:8b
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.5
LLM_CHUNK_CHARS=12000
LLM_STRUCTURED_FALLBACK=true

# Agenda detection. LLM detection is disabled unless this is true or a request
# passes a model/prompt. Long unknown-agenda transcripts are chunked by lines.
AGENDA_DETECTION_USE_LLM=false
AGENDA_DETECTION_TIMEOUT_SECONDS=8
AGENDA_DETECTION_CHUNK_LINES=160
AGENDA_DETECTION_CHUNK_OVERLAP_LINES=12

# Persistence and job handling
PERSISTENCE_DB_PATH=data/sessions.sqlite3
JOB_MAX_AGE_SECONDS=7200
JOB_MAX_COUNT=100
DELETE_UPLOADS_ON_JOB_CLEANUP=false
DELETE_UPLOADS_ON_CANCEL_OR_FAILURE=true
MAX_UPLOAD_BYTES=524288000
TRANSCRIPTION_CONCURRENCY=1
PIPELINE_CONCURRENCY=1
SUMMARY_CONCURRENCY=1
