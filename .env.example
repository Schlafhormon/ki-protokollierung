# Protokollierungsassistenz - Environment Configuration
# Copy this file to .env to customize settings
#
# NOTE: When using pre-built Docker images from ghcr.io, no configuration
# is required! The default settings work out of the box.

# ==================================================
# OPTIONAL: Whisper Configuration
# ==================================================
# Model size: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=large-v2

# Device: cpu, cuda, auto (auto-detect)
WHISPER_DEVICE=cpu

# Batch size for transcription (reduce if running out of memory)
WHISPER_BATCH_SIZE=16

# Language code
WHISPER_LANGUAGE=de

# ==================================================
# OPTIONAL: LLM Configuration
# ==================================================
# Model for summarization (must be available in Ollama)
LLM_MODEL=qwen3:8b

# OpenAI-compatible endpoint for local Ollama
LLM_BASE_URL=http://localhost:11434/v1

# Request timeout and retry behavior for transient LLM errors
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2

# Chunk long TOP transcripts before summarization
LLM_CHUNK_CHARS=12000

# Fall back to plain text when structured LLM output cannot be parsed
LLM_STRUCTURED_FALLBACK=true

# ==================================================
# FOR DEVELOPERS ONLY: Building Images Locally
# ==================================================
# HuggingFace token is ONLY needed if you're building Docker images locally
# instead of using the pre-built images from ghcr.io
#
# Get your token at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
