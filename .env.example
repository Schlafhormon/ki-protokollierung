# Protokollierungsassistenz - Environment Configuration
# Copy this file to .env to customize settings
#
# NOTE: When using pre-built Docker images from ghcr.io, no configuration
# is required! The default settings work out of the box.

# ==================================================
# OPTIONAL: Runtime Image Versions
# ==================================================
# Defaults track the existing moving tags. For a stable release, pin these to a
# published release tag instead, for example:
# FRONTEND_IMAGE=ghcr.io/aihpi/pilotproject-protokollierungsassistenz/frontend:v1.2.3
# BACKEND_IMAGE=ghcr.io/aihpi/pilotproject-protokollierungsassistenz/backend:v1.2.3
# BACKEND_GPU_IMAGE=ghcr.io/aihpi/pilotproject-protokollierungsassistenz/backend:v1.2.3-gpu
# OLLAMA_IMAGE=ollama/ollama:0.12.10
#
# Setup scripts also accept PROTOKOLL_IMAGE_TAG=v1.2.3 and
# PROTOKOLL_PULL_POLICY=missing|always|never.

# ==================================================
# OPTIONAL: Whisper Configuration
# ==================================================
# Model size: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=large-v2

# Device: cpu, cuda, auto (auto-detect)
WHISPER_DEVICE=cpu

# Batch size for transcription (reduce if running out of memory)
WHISPER_BATCH_SIZE=16

# Language code
WHISPER_LANGUAGE=de

# ==================================================
# OPTIONAL: LLM Configuration
# ==================================================
# Model for summarization (must be available in Ollama)
LLM_MODEL=qwen3:8b

# OpenAI-compatible endpoint for local Ollama
LLM_BASE_URL=http://localhost:11434/v1

# Request timeout and retry behavior for transient LLM errors
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.5

# Chunk long TOP transcripts before summarization
LLM_CHUNK_CHARS=12000

# Fall back to plain text when structured LLM output cannot be parsed
LLM_STRUCTURED_FALLBACK=true

# ==================================================
# OPTIONAL: Speaker Memory and Matching
# ==================================================
# Persistent speaker memory is opt-in from the UI. When disabled by the user,
# local embeddings may be extracted for the current job, but no global profile
# suggestions or profile embeddings are created.
SPEAKER_EMBEDDING_ENABLED=true
SPEAKER_EMBEDDING_MODEL=pyannote/embedding
SPEAKER_MATCH_AUTO_THRESHOLD=0.82
SPEAKER_MATCH_SUGGEST_THRESHOLD=0.72
SPEAKER_EMBEDDING_MIN_SECONDS=8.0
SPEAKER_EMBEDDING_MIN_SEGMENT_SECONDS=1.5
SPEAKER_EMBEDDING_MAX_SEGMENT_SECONDS=12.0
SPEAKER_EMBEDDING_MAX_SEGMENTS=8

# ==================================================
# OPTIONAL: Agenda Detection and Pipeline
# ==================================================
# LLM agenda detection is off by default unless the UI/API passes a model or
# prompt. Long unknown-agenda transcripts are chunked by line count.
AGENDA_DETECTION_USE_LLM=false
AGENDA_DETECTION_TIMEOUT_SECONDS=8
AGENDA_DETECTION_CHUNK_LINES=160
AGENDA_DETECTION_CHUNK_OVERLAP_LINES=12

# End-to-end pipeline worker concurrency. Pipeline jobs are marked failed on
# backend restart, so users can resume the saved session or restart clearly.
PIPELINE_CONCURRENCY=1

# ==================================================
# OPTIONAL: Persistence and Job Handling
# ==================================================
# Docker Compose mounts ./data to /app/data so sessions survive container
# recreation and setup stop/start cycles.
PERSISTENCE_DB_PATH=/app/data/sessions.sqlite3

# Cleanup controls for in-memory job cache and retained audio uploads.
JOB_MAX_AGE_SECONDS=7200
JOB_MAX_COUNT=100
DELETE_UPLOADS_ON_JOB_CLEANUP=false
DELETE_UPLOADS_ON_CANCEL_OR_FAILURE=true
MAX_UPLOAD_BYTES=524288000
TRANSCRIPTION_CONCURRENCY=1

# ==================================================
# OPTIONAL: Opt-in Telemetry
# ==================================================
# Telemetry is only sent after explicit user opt-in in the UI.
# Leave TELEMETRY_WEBHOOK_URL empty to disable outbound telemetry.
TELEMETRY_WEBHOOK_URL=

# Local JSONL backups are disabled by default. If enabled, only aggregate
# telemetry payloads are stored and retention is enforced at write time.
TELEMETRY_BACKUP_ENABLED=false
TELEMETRY_BACKUP_RETENTION_DAYS=14
TELEMETRY_BACKUP_MAX_FILES=30
TELEMETRY_BACKUP_DIR=/app/data/telemetry_backup

# ==================================================
# FOR DEVELOPERS ONLY: Building Images Locally
# ==================================================
# HuggingFace token is ONLY needed if you're building Docker images locally
# instead of using the pre-built images from ghcr.io
#
# Get your token at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
